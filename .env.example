# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/angogas
DB_USER=angogas
DB_PASSWORD=angogas123

# JWT — usar chave longa e aleatória em produção
JWT_SECRET=muda_para_uma_chave_segura_de_256_bits
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Firebase Cloud Messaging (opcional em dev)
FCM_ENABLED=false
FIREBASE_SERVICE_ACCOUNT=path/to/firebase-service-account.json

# Multicaixa Express (Fase 3)
# MULTICAIXA_API_KEY=
# MULTICAIXA_BASE_URL=https://api.multicaixa.ao

# Cloudinary (uploads de imagens)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
